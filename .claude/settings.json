{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "60"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Write",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(fd *)",
      "Bash(find *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(git --no-pager *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(npm run build *)",
      "Bash(npm run dev *)",
      "Bash(npm run lint *)",
      "Bash(npm run test *)",
      "Bash(npm test *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(terraform fmt *)",
      "Bash(terraform import *)",
      "Bash(terraform init *)",
      "Bash(terraform plan *)",
      "Bash(terraform state list *)",
      "Bash(terraform state show *)",
      "Bash(terraform validate *)",
      "Bash(uniq *)",
      "Bash(uv add *)",
      "Bash(uv sync *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(git rebase *)",
      "Bash(git reset)",
      "Bash(git reset *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(terraform force-unlock *)",
      "Bash(terraform state rm *)",
      "Bash(wget *)",
      "Bash(yarn publish *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(gh pr create *)",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(rm *)",
      "Bash(terraform state mv *)"
    ]
  },
  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/src/github.com/mostlyfine/agent-tools/scripts/claude-save-log.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/src/github.com/mostlyfine/agent-tools/scripts/statusline.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "andrej-karpathy-skills@multica-ai/andrej-karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "multica-ai/andrej-karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "multica-ai/andrej-karpathy-skills"
      }
    }
  },
  "language": "Japanese",
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoCompactEnabled": true,
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 30,
  "showTurnDuration": true
}
