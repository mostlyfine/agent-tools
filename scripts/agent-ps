#!/usr/bin/env python3
"""agent-ps: list Claude Code / GitHub Copilot CLI / OpenAI Codex CLI sessions running in tmux panes."""
from __future__ import annotations

import argparse
import os
import re
import select
import shutil
import signal
import subprocess
import sys
import termios
import time
import tty
import unicodedata
from collections.abc import Callable
from concurrent.futures import ThreadPoolExecutor
from dataclasses import dataclass
from pathlib import Path
from typing import NamedTuple


def shorten_dir(path: str) -> str:
    """Return only the final directory name (basename) for display."""
    try:
        p = Path(path).expanduser()
        name = p.name
        if name:
            return name
        # For root (e.g. '/') p.name is empty — return the path itself
        return str(p)
    except Exception:
        return path


_TASK_MAX_LEN = 55
_DIR_MAX_LEN = 30

_STATUS_RUNNING = "running"
_STATUS_IDLE = "idle"
_STATUS_WAITING = "waiting_for_input"
_STATUS_UNKNOWN = "unknown"

_CLAUDE_IDLE_MARKS = ("✳", "✴", "✺", "✻")
_CLAUDE_CHOICE_CURSOR_RE = re.compile(r"❯\s+\d+\.")
_CLAUDE_NAV_HINT_RE = re.compile(
    r"Do you want to (proceed|allow)|Press Enter to (confirm|submit)"
    r"|run a dynamic workflow\?|waiting for permission|tab to amend"
    r"|ctrl\+e to explain|review your answers|skip interview and plan immediately",
    re.IGNORECASE,
)
_NON_CONTENT_BORDER_RE = re.compile(r"^[\s│╰╯─╭╮]*$")


def _is_braille(ch: str) -> bool:
    # Claude spinner uses Braille Patterns block (U+2800–U+28FF)
    return bool(ch) and 0x2800 <= ord(ch) <= 0x28FF


def _visual_width(s: str) -> int:
    return sum(2 if unicodedata.east_asian_width(ch) in ("W", "F") else 1 for ch in s)


def _ljust_visual(s: str, width: int) -> str:
    return s + " " * max(0, width - _visual_width(s))


def _truncate(s: str, max_len: int) -> str:
    assert max_len >= 3
    return s[:max_len - 3] + "..." if len(s) > max_len else s


def claude_task(title: str) -> str:
    task = title
    if task and (task[0] in _CLAUDE_IDLE_MARKS or _is_braille(task[0])):
        task = task[1:]
    task = task.removeprefix("Claude Code").lstrip()
    return _truncate(task, _TASK_MAX_LEN)


def copilot_task(title: str) -> str:
    return _truncate(title.removeprefix("\U0001f916").lstrip(), _TASK_MAX_LEN)


_COPILOT_NAV_HINT_RE = re.compile(
    r"↑/?↓ to (navigate|select)|(?:Press )?Enter to (select|confirm|submit|continue)"
    r"|Enter accept",
    re.IGNORECASE,
)


def copilot_title_status(title: str) -> str:
    return _STATUS_RUNNING if title.startswith("\U0001f916") else _STATUS_IDLE


def _status_from_nav_hint(title: str, content: str, nav_hint_re, title_status_fn) -> str:
    lines = content.splitlines()
    if _detect_waiting_for_input(lines, nav_hint_re):
        return _STATUS_WAITING
    return title_status_fn(title)


def copilot_status(title: str, content: str) -> str:
    return _status_from_nav_hint(title, content, _COPILOT_NAV_HINT_RE, copilot_title_status)


def _is_node_child_of(pid: str, name: str) -> bool:
    """Check whether a process named `name` is running as a child of `pid`
    (for CLIs that get launched via a node wrapper, e.g. npm-installed binaries)."""
    try:
        pgrep = subprocess.run(
            ["pgrep", "-P", pid],
            capture_output=True,
            text=True,
            check=False,
        )
    except OSError:
        return False
    if pgrep.returncode != 0 or not pgrep.stdout.strip():
        return False

    child_pids = pgrep.stdout.split()
    try:
        ps_out = subprocess.run(
            ["ps", "-o", "command=", "-p", *child_pids],
            capture_output=True,
            text=True,
            check=False,
        )
    except OSError:
        return False
    if ps_out.returncode != 0:
        return False
    return name in ps_out.stdout


def is_copilot_pane(cmd: str, pid: str) -> bool:
    # copilot sometimes runs as a child of node — check child PIDs too
    if cmd == "copilot":
        return True
    if cmd != "node":
        return False
    return _is_node_child_of(pid, "copilot")


def claude_title_status(title: str) -> str:
    if not title:
        return _STATUS_UNKNOWN
    first = title[0]
    if first in _CLAUDE_IDLE_MARKS:
        return _STATUS_IDLE
    if _is_braille(first):
        return _STATUS_RUNNING
    return _STATUS_UNKNOWN


def _content_has_braille(content: str) -> bool:
    return any(_is_braille(ch) for ch in content)


def _has_only_borders_after(lines, start_idx) -> bool:
    for line in lines[start_idx + 1:]:
        if not _NON_CONTENT_BORDER_RE.match(line):
            return False
    return True


def _detect_waiting_for_input(lines: list, pattern: re.Pattern) -> bool:
    for i in range(len(lines) - 1, -1, -1):
        line = lines[i]
        if pattern.search(line):
            return _has_only_borders_after(lines, i)
        if not _NON_CONTENT_BORDER_RE.match(line):
            return False
    return False


def claude_status(title: str, content: str) -> str:
    if _CLAUDE_CHOICE_CURSOR_RE.search(content):
        return _STATUS_WAITING
    lines = content.splitlines()
    if _detect_waiting_for_input(lines, _CLAUDE_NAV_HINT_RE):
        return _STATUS_WAITING
    if _content_has_braille(content):
        return _STATUS_RUNNING
    return claude_title_status(title)


_CLAUDE_VERSION_CMD_RE = re.compile(r"^\d+\.\d+\.\d+$")
_CLAUDE_TITLE_MARK = "Claude Code"


def is_claude_pane(cmd: str, title: str) -> bool:
    if _CLAUDE_VERSION_CMD_RE.match(cmd or ""):
        return True
    if _CLAUDE_TITLE_MARK in (title or ""):
        return True
    return False


_CODEX_TITLE_BLOCKED_MARK = "Action Required"
_CODEX_NAV_HINT_RE = re.compile(
    r"press enter to confirm or esc to cancel"
    r"|enter to submit answer"
    r"|enter to submit all"
    r"|allow command\?",
    re.IGNORECASE,
)


def codex_title_status(title: str) -> str:
    if not title:
        return _STATUS_UNKNOWN
    if _CODEX_TITLE_BLOCKED_MARK in title:
        return _STATUS_WAITING
    if _is_braille(title[0]):
        return _STATUS_RUNNING
    return _STATUS_IDLE


def codex_status(title: str, content: str) -> str:
    return _status_from_nav_hint(title, content, _CODEX_NAV_HINT_RE, codex_title_status)


def codex_task(title: str) -> str:
    task = title
    if task and _is_braille(task[0]):
        task = task[1:].lstrip()
    return _truncate(task, _TASK_MAX_LEN)


def is_codex_pane(cmd: str, pid: str) -> bool:
    # codex sometimes runs as a child of node (npm-installed wrapper) — check child PIDs too
    if cmd == "codex":
        return True
    if cmd != "node":
        return False
    return _is_node_child_of(pid, "codex")


@dataclass
class PaneRaw:
    pane_id: str
    cmd: str
    dir: str
    pid: str
    title: str


@dataclass
class Pane:
    agent: str
    pane_id_num: str
    status: str
    task: str
    dir: str
    label: str = ""


def reconcile_selection(selected, panes):
    if selected is None:
        return None
    return selected if selected in {p.pane_id_num for p in panes} else None


_DIR_UP_KEYS = {"up", "k"}
_DIR_DOWN_KEYS = {"down", "j"}


def handle_key(key, panes, selected):
    if key == "enter":
        if selected is None:
            return None, None
        return selected, "focus"

    if key == "q":
        return None, "quit"

    if key == "escape":
        return None, None

    if key == "h":
        return selected, "toggle_help"

    if key in _DIR_UP_KEYS or key in _DIR_DOWN_KEYS:
        if not panes:
            return None, None
        if selected is None:
            return panes[0].pane_id_num, None
        ids = [p.pane_id_num for p in panes]
        try:
            idx = ids.index(selected)
        except ValueError:
            return panes[0].pane_id_num, None
        if key in _DIR_UP_KEYS:
            idx = max(0, idx - 1)
        else:
            idx = min(len(ids) - 1, idx + 1)
        return ids[idx], None

    return selected, None


# watch_loop always writes a hint line + a blank line before render()'s output,
# so a click's terminal row must be offset by these 2 lines to index into it.
_WATCH_BANNER_ROWS = 2


def handle_click(cy, panes, selected, horizontal):
    row = cy - 1 - _WATCH_BANNER_ROWS
    pane_id_num = _pane_at_row(panes, row, horizontal)
    if pane_id_num is None:
        return selected, None
    return pane_id_num, "focus"


_KEY_MAP = {
    b"\r": "enter",
    b"\n": "enter",
    b"j": "j",
    b"k": "k",
    b"q": "q",
    b"h": "h",
    b"\x1b": "escape",
    b"\x1b[A": "up",
    b"\x1b[B": "down",
}

# SGR extended mouse reporting: ESC [ < Cb ; Cx ; Cy (M=press | m=release)
_MOUSE_SGR_RE = re.compile(rb"^\x1b\[<(\d+);(\d+);(\d+)([Mm])$")
_MOUSE_WHEEL_BIT = 0x40
_MOUSE_BUTTON_MASK = 0x03
_MOUSE_LEFT_BUTTON = 0

# CSI sequences terminate with a byte in this range ('@'-'~')
_CSI_FINAL_BYTES = frozenset(range(0x40, 0x7F))


def _parse_mouse_click(buf):
    m = _MOUSE_SGR_RE.match(buf)
    if not m:
        return None
    cb, cx, cy, kind = int(m[1]), int(m[2]), int(m[3]), m[4]
    is_left_press = (
        kind == b"M"
        and not cb & _MOUSE_WHEEL_BIT
        and (cb & _MOUSE_BUTTON_MASK) == _MOUSE_LEFT_BUTTON
    )
    return ("click", cx, cy) if is_left_press else None


def _classify_key(buf):
    mapped = _KEY_MAP.get(buf)
    if mapped:
        return mapped
    return _parse_mouse_click(buf) or "other"


def wait_for_key(timeout):
    """Block up to `timeout` seconds for a key. Returns key string, a
    ("click", col, row) tuple, or None."""
    fd = sys.stdin.fileno()
    rlist, _, _ = select.select([sys.stdin], [], [], timeout)
    if not rlist:
        return None
    try:
        first = os.read(fd, 1)
    except OSError:
        return None
    if first != b"\x1b":
        return _classify_key(first)

    rlist, _, _ = select.select([sys.stdin], [], [], 0.05)
    if not rlist:
        return _classify_key(first)
    try:
        second = os.read(fd, 1)
    except OSError:
        return _classify_key(first)
    buf = first + second
    if second != b"[":
        return _classify_key(buf)

    # CSI sequence (arrow key or SGR mouse report): read until the final byte,
    # since mouse reports have variable-length coordinate digits.
    while True:
        rlist, _, _ = select.select([sys.stdin], [], [], 0.05)
        if not rlist:
            break
        try:
            ch = os.read(fd, 1)
        except OSError:
            break
        if not ch:
            break  # EOF: stdin closed mid-sequence, stop reading instead of spinning
        buf += ch
        if ch[0] in _CSI_FINAL_BYTES:
            break
    return _classify_key(buf)


def focus_pane(pane_id_num):
    # select-window first to handle cross-window panes; select-pane then focuses within
    target = f"%{pane_id_num}"
    for args in (
        ["tmux", "select-window", "-t", target],
        ["tmux", "select-pane", "-t", target],
    ):
        try:
            subprocess.run(
                args,
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except OSError:
            pass


_PANE_FORMAT = "#{pane_id}|#{pane_current_command}|#{pane_current_path}|#{pane_pid}|#{pane_title}"


def current_session() -> str:
    out = subprocess.run(
        ["tmux", "display-message", "-p", "#S"],
        capture_output=True,
        text=True,
        check=False,
    )
    if out.returncode != 0:
        raise RuntimeError(f"tmux display-message failed: {out.stderr.strip()}")
    return out.stdout.strip()


def list_panes(session: str) -> list:
    cmd = ["tmux", "list-panes", "-t", session, "-s", "-F", _PANE_FORMAT]
    out = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if out.returncode != 0:
        raise RuntimeError(f"tmux list-panes failed: {out.stderr.strip()}")
    panes = []
    for line in out.stdout.splitlines():
        if not line:
            continue
        parts = line.split("|", 4)
        if len(parts) != 5:
            continue
        panes.append(PaneRaw(*parts))
    return panes


def capture_pane(pane_id: str) -> str:
    out = subprocess.run(
        ["tmux", "capture-pane", "-t", pane_id, "-p"],
        capture_output=True,
        text=True,
        check=False,
    )
    if out.returncode != 0:
        return ""
    return out.stdout


class _AgentCfg(NamedTuple):
    name: str
    label: str
    is_pane: Callable[["PaneRaw"], bool]
    get_status: Callable[[str, str], str]
    get_task: Callable[[str], str]


def _is_claude(raw: PaneRaw) -> bool:
    return is_claude_pane(raw.cmd, raw.title)


def _is_copilot(raw: PaneRaw) -> bool:
    return is_copilot_pane(raw.cmd, raw.pid)


def _is_codex(raw: PaneRaw) -> bool:
    return is_codex_pane(raw.cmd, raw.pid)


_AGENT_CONFIGS = [
    _AgentCfg("claude", "Claude", _is_claude, claude_status, claude_task),
    _AgentCfg("copilot", "Copilot", _is_copilot, copilot_status, copilot_task),
    _AgentCfg("codex", "Codex", _is_codex, codex_status, codex_task),
]

_AGENT_COL_WIDTH = max(len(cfg.name) for cfg in _AGENT_CONFIGS) + 1


def collect_panes(session: str) -> list:
    raws = list_panes(session)
    agent_raws = []
    for raw in raws:
        pane_id_num = raw.pane_id.removeprefix("%")
        for cfg in _AGENT_CONFIGS:
            if cfg.is_pane(raw):
                agent_raws.append((raw, pane_id_num, cfg))
                break

    def _build(args):
        raw, pane_id_num, cfg = args
        content = capture_pane(raw.pane_id)
        return Pane(
            agent=cfg.name,
            pane_id_num=pane_id_num,
            status=cfg.get_status(raw.title, content),
            task=cfg.get_task(raw.title),
            dir=shorten_dir(raw.dir),
            label=cfg.label,
        )

    if not agent_raws:
        return []
    with ThreadPoolExecutor(max_workers=min(8, len(agent_raws))) as ex:
        return list(ex.map(_build, agent_raws))


_BOLD = "\033[1m"
_DIM = "\033[2m"
_RESET = "\033[0m"
_REVERSE = "\033[7m"

_STATUS_GLYPH = {
    _STATUS_RUNNING: "🟡",
    _STATUS_IDLE: "🔵",
    _STATUS_WAITING: "🔴",
    _STATUS_UNKNOWN: "🟢",
}

def _status_glyph(status: str) -> str:
    return _STATUS_GLYPH.get(status, "?")


def _reverse_wrap(s: str) -> str:
    return f"{_REVERSE}{s.replace(_RESET, _RESET + _REVERSE)}{_RESET}"


def _marker(pane_id_num: str, selected_pane_id) -> str:
    return "▶ " if pane_id_num == selected_pane_id else "  "


def _terminal_sep() -> str:
    return "─" * shutil.get_terminal_size().columns


def _render_table(panes, session, selected_pane_id=None):
    lines = []
    lines.append(f"{_BOLD}  {'AGENT':<{_AGENT_COL_WIDTH}}{'ID':>5}  {'TASK':<{_TASK_MAX_LEN}} DIR{_RESET}")
    lines.append(_terminal_sep())
    if not panes:
        lines.append(f"No agent sessions found in tmux session: {session}")
    else:
        for p in panes:
            marker = _marker(p.pane_id_num, selected_pane_id)
            agent = _truncate(p.agent, _AGENT_COL_WIDTH)
            dir_ = _truncate(p.dir, _DIR_MAX_LEN)
            row = (
                f"{marker}{_status_glyph(p.status)}  "
                f"{_ljust_visual(agent, _AGENT_COL_WIDTH)}"
                f"{_DIM}{p.pane_id_num:>5}{_RESET}  "
                f"{_ljust_visual(p.task, _TASK_MAX_LEN)} {_DIM}{dir_}{_RESET}"
            )
            if p.pane_id_num == selected_pane_id:
                row = _reverse_wrap(row)
            lines.append(row)
    return "\n".join(lines)


def _render_horizontal(panes, session, selected_pane_id=None):
    if not panes:
        return f"No agent sessions found in tmux session: {session}"

    blocks = []
    for p in panes:
        marker = _marker(p.pane_id_num, selected_pane_id)
        line1 = f"{marker}{_status_glyph(p.status)}  {p.agent}: {p.pane_id_num}"
        line2 = p.task
        line3 = f"{_DIM}{_truncate(p.dir, _DIR_MAX_LEN)}{_RESET}"
        block = f"{line1}\n{line2}\n{line3}"
        if p.pane_id_num == selected_pane_id:
            block = _reverse_wrap(block)
        blocks.append(f"{block}\n{_terminal_sep()}")
    return "\n".join(blocks)


def render(panes, session, selected_pane_id=None, horizontal: bool = False):
    if horizontal:
        return _render_horizontal(panes, session, selected_pane_id)
    return _render_table(panes, session, selected_pane_id)


# These row counts must stay in sync with _render_table()/_render_horizontal():
# table has a 2-line header before pane rows; each horizontal block is 4 lines
# (3 clickable content lines + 1 trailing separator).
_TABLE_HEADER_ROWS = 2
_HORIZONTAL_BLOCK_ROWS = 4
_HORIZONTAL_CLICKABLE_ROWS = _HORIZONTAL_BLOCK_ROWS - 1


def _pane_at_row(panes, row: int, horizontal: bool):
    """Resolve a single 0-indexed row of render()'s output directly to its
    pane_id_num, without building a map for the whole pane list."""
    if horizontal:
        idx, offset = divmod(row, _HORIZONTAL_BLOCK_ROWS)
        if offset >= _HORIZONTAL_CLICKABLE_ROWS:
            return None
    else:
        idx = row - _TABLE_HEADER_ROWS
    return panes[idx].pane_id_num if 0 <= idx < len(panes) else None


def parse_args(argv=None):
    parser = argparse.ArgumentParser(
        prog="agent-ps",
        description="List Claude Code / GitHub Copilot CLI / OpenAI Codex CLI sessions in tmux",
    )
    parser.add_argument("-w", "--watch", nargs="?", const=1, type=int, default=None,
                        help="watch mode (default 1s interval)")
    parser.add_argument("-n", "--notify", action="store_true",
                        help="send terminal notification on idle/waiting transitions")
    parser.add_argument("-H", "--horizontal", action="store_true",
                        help="render each session as a stacked card instead of a table row")
    ns = parser.parse_args(argv)

    watch_set = ns.watch is not None
    interval = ns.watch if ns.watch else 1
    return argparse.Namespace(
        watch=watch_set, interval=interval, notify=ns.notify, horizontal=ns.horizontal,
    )


def check_deps() -> None:
    if shutil.which("tmux") is None:
        print("error: tmux is not installed", file=sys.stderr)
        raise SystemExit(1)
    if not os.environ.get("TMUX"):
        print("error: agent-ps must be run inside a tmux session", file=sys.stderr)
        raise SystemExit(1)


def main(argv=None) -> int:
    args = parse_args(argv)
    check_deps()
    session = current_session()
    if args.watch:
        watch_loop(args, session)
        return 0
    panes = collect_panes(session)
    print(render(panes, session, horizontal=args.horizontal))
    return 0


_ANSI_CAPS = {
    "civis": "\033[?25l",
    "cnorm": "\033[?25h",
    "clear": "\033[2J\033[H",
    "home": "\033[H",
    "ed": "\033[J",
    "mouse_on": "\033[?1000h\033[?1006h",
    "mouse_off": "\033[?1000l\033[?1006l",
}


def _tput(arg: str) -> None:
    seq = _ANSI_CAPS.get(arg)
    if seq:
        sys.stdout.write(seq)
        sys.stdout.flush()


def watch_loop(args, session):
    needs_clear = True
    is_tty = sys.stdin.isatty()
    fd = sys.stdin.fileno() if is_tty else -1
    old_termios = termios.tcgetattr(fd) if is_tty else None

    def _restore_tty():
        if old_termios is not None:
            try:
                termios.tcsetattr(fd, termios.TCSADRAIN, old_termios)
            except termios.error:
                pass

    def _on_winch(signum, frame):
        nonlocal needs_clear
        needs_clear = True

    def _on_exit(signum, frame):
        raise SystemExit(0)

    signal.signal(signal.SIGINT, _on_exit)
    signal.signal(signal.SIGTERM, _on_exit)
    if hasattr(signal, "SIGWINCH"):
        signal.signal(signal.SIGWINCH, _on_winch)

    if is_tty:
        tty.setcbreak(fd)
        _tput("mouse_on")
    _tput("civis")
    _tput("clear")

    selected_pane_id = None
    show_help = False
    prev_status: dict = {}
    try:
        while True:
            try:
                panes = collect_panes(session)
            except Exception as e:
                print(f"agent-ps: {e}", file=sys.stderr)
                panes = []

            if args.notify:
                prev_status = check_and_notify(prev_status, panes)

            selected_pane_id = reconcile_selection(selected_pane_id, panes)

            if needs_clear:
                _tput("clear")
                needs_clear = False

            buf = render(panes, session, selected_pane_id=selected_pane_id, horizontal=args.horizontal)
            _tput("home")
            label = f"agent-ps [{session}]"
            if show_help:
                controls = (
                    "↑↓/jk select, Enter focus, click select+focus, "
                    "Esc cancel, q quit, Ctrl-C stop, h hide help"
                )
            else:
                controls = "h help"
            sys.stdout.write(
                f"{_DIM}{label}  (every {args.interval}s, {controls}){_RESET}"
                f"\033[K\n\033[K\n"
            )
            sys.stdout.write(buf.replace("\n", "\033[K\n") + "\033[K")
            sys.stdout.flush()
            _tput("ed")

            if is_tty:
                key = wait_for_key(args.interval)
                if key is None:
                    continue
                if isinstance(key, tuple) and key[0] == "click":
                    _, _, cy = key
                    selected_pane_id, action = handle_click(
                        cy, panes, selected_pane_id, args.horizontal
                    )
                else:
                    selected_pane_id, action = handle_key(key, panes, selected_pane_id)
                if action == "quit":
                    break
                if action == "focus" and selected_pane_id is not None:
                    focus_pane(selected_pane_id)
                if action == "toggle_help":
                    show_help = not show_help
            else:
                try:
                    time.sleep(args.interval)
                except KeyboardInterrupt:
                    break
    finally:
        _restore_tty()
        _tput("mouse_off")
        _tput("cnorm")
        _tput("clear")


def _escape_applescript(s: str) -> str:
    return s.replace("\\", "\\\\").replace('"', '\\"')


_NOTIF_TITLE = "agent-ps"
_IN_TMUX = "TMUX" in os.environ
_TERM_PROGRAM = os.environ.get("TERM_PROGRAM", "")


def _notify_applescript(message: str) -> None:
    try:
        subprocess.Popen(
            ["osascript", "-e",
             f'display notification "{_escape_applescript(message)}" with title "{_NOTIF_TITLE}"'],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    except OSError:
        pass


def send_notification(message: str) -> None:
    if _IN_TMUX:
        sys.stdout.write(f"\x1bPtmux;\x1b\x1b]9;{message}\x07\x1b\\")
        sys.stdout.flush()
    elif _TERM_PROGRAM in ("iTerm.app", "ghostty"):
        sys.stdout.write(f"\x1b]9;{message}\x07")
        sys.stdout.flush()
    elif sys.platform == "darwin":
        _notify_applescript(message)


def check_and_notify(prev_status: dict, panes: list) -> dict:
    new_prev = {}
    for p in panes:
        prev = prev_status.get(p.pane_id_num)
        # Preserve the last known status across brief "unknown" transitions so the
        # idle notification isn't lost when the spinner disappears before the title updates.
        new_prev[p.pane_id_num] = (
            p.status if p.status != _STATUS_UNKNOWN
            else (prev if prev is not None else _STATUS_UNKNOWN)
        )
        if prev != _STATUS_RUNNING:
            continue
        if p.status not in (_STATUS_IDLE, _STATUS_WAITING):
            continue
        agent = p.label or p.agent
        task = p.task or f"Pane %{p.pane_id_num}"
        send_notification(f"[{agent}] {task} {p.status}")
    return new_prev


if __name__ == "__main__":
    raise SystemExit(main())
